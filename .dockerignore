# Dependencies
# Exclude node_modules at EVERY depth (root, apps/*, packages/*, and nested pnpm
# node_modules). The previous explicit per-package list missed newer packages
# (ai-api, bx-rq, pbx-data, april-theme, ...), which bloated the build context to
# ~5GB and tripped Docker's tar on a pnpm symlink in packages/ai-api/node_modules.
node_modules
**/node_modules
.pnpm-store
**/.pnpm-store



# Build outputs (at every depth)
dist
**/dist
.next
**/.next
build
**/build
*.tsbuildinfo
**/*.tsbuildinfo



# Version control
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage
.nyc_output

# Misc
.DS_Store
*.pem
